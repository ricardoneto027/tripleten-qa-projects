    {
      "name": "Criar kit 8 com script 20 produtos",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const alreadyInKit = []; // kit vazio, sem exceções",
              "const totalToAdd = 29;",
              "",
              "let productsList = [];",
              "let id = 1;",
              "",
              "while (productsList.length < totalToAdd) {",
              "    if (!alreadyInKit.includes(id)) {",
              "        productsList.push({ \"id\": id, \"quantity\": 1 });",
              "    }",
              "    id++;",
              "}",
              "",
              "pm.environment.set(\"productsList\", JSON.stringify(productsList));"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"productsList\": {{productsList}}\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{server_url}}/api/v1/kits/8/products",
